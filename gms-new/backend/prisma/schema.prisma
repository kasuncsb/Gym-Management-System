// This is your Prisma schema file for PowerWorld Gyms Management System
// Database: MySQL (running on Oracle VM)
// Normalized to 3NF with audit trails and Sri Lankan context

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Enums
enum MemberStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PAID
  PENDING
  FAILED
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum EventType {
  IN
  OUT
}

enum AccessStatus {
  GRANTED
  DENIED
}

enum AccessType {
  ENTRY
  EXIT
}

enum WorkoutStatus {
  PENDING
  COMPLETED
  SKIPPED
}

enum RecurrenceType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

enum EquipmentStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

enum StaffRole {
  ADMIN
  INSTRUCTOR
  RECEPTIONIST
  MANAGER
}

enum TrainerStatus {
  ACTIVE
  INACTIVE
}

// Main Tables

model Member {
  memberId         String      @id @default(cuid()) @map("member_id")
  name             String      @db.VarChar(100)
  email            String      @unique @db.VarChar(100)
  phone            String?     @db.VarChar(15)
  dateOfBirth      DateTime?   @map("date_of_birth") @db.Date
  joinDate         DateTime    @default(now()) @map("join_date") @db.Date
  emergencyContact String?     @map("emergency_contact") @db.VarChar(200)
  passwordHash     String      @map("password_hash") @db.VarChar(255)
  qrCodeToken      String      @unique @map("qr_code_token") @db.VarChar(100)
  status           MemberStatus @default(ACTIVE)
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  deletedAt        DateTime?   @map("deleted_at")

  // Relations
  subscriptions    Subscription[]
  attendances      Attendance[]
  doorAccesses     DoorAccess[]
  appointments     Appointment[]
  workoutSchedules WorkoutSchedule[]
  workoutSessions  WorkoutSession[]
  progress         Progress[]
  payments         Payment[]

  @@index([email])
  @@index([qrCodeToken])
  @@index([status])
  @@map("members")
}

model Trainer {
  trainerId      String        @id @default(cuid()) @map("trainer_id")
  name           String        @db.VarChar(100)
  specialization String?       @db.VarChar(100)
  email          String        @unique @db.VarChar(100)
  phone          String?       @db.VarChar(15)
  availability   Json?         // JSON: {"mon": ["09:00-17:00"], "tue": ["09:00-17:00"]}
  hourlyRate     Decimal?      @map("hourly_rate") @db.Decimal(8, 2)
  status         TrainerStatus @default(ACTIVE)
  passwordHash   String        @map("password_hash") @db.VarChar(255)
  qrHash         String        @unique @map("qr_hash") @db.VarChar(100)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  // Relations
  appointments Appointment[]
  doorAccesses DoorAccess[]

  @@index([email])
  @@index([status])
  @@map("trainers")
}

model Staff {
  staffId      String    @id @default(cuid()) @map("staff_id")
  name         String    @db.VarChar(100)
  role         StaffRole
  email        String    @unique @db.VarChar(100)
  phone        String?   @db.VarChar(15)
  permissions  Json?     // JSON: {"can_manage_members": true, "can_view_reports": true}
  hireDate     DateTime  @map("hire_date") @db.Date
  status       MemberStatus @default(ACTIVE)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  // Relations
  configChanges SystemConfig[]

  @@index([email])
  @@index([role])
  @@map("staff")
}

model SubscriptionPlan {
  planId       String   @id @default(cuid()) @map("plan_id")
  planName     String   @map("plan_name") @db.VarChar(50)
  description  String?  @db.Text
  price        Decimal  @db.Decimal(10, 2)
  durationDays Int      @map("duration_days")
  accessHours  String?  @map("access_hours") @db.VarChar(100)
  facilities   Json?    // JSON: {"gym": true, "pool": false, "sauna": true}
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  // Relations
  subscriptions Subscription[]

  @@index([planName])
  @@map("subscription_plans")
}

model Subscription {
  subscriptionId String             @id @default(cuid()) @map("subscription_id")
  memberId       String             @map("member_id")
  planId         String             @map("plan_id")
  startDate      DateTime           @map("start_date") @db.Date
  endDate        DateTime           @map("end_date") @db.Date
  status         SubscriptionStatus @default(ACTIVE)
  autoRenew      Boolean            @default(true) @map("auto_renew")
  paymentStatus  PaymentStatus      @default(PENDING) @map("payment_status")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  deletedAt      DateTime?          @map("deleted_at")

  // Relations
  member   Member           @relation(fields: [memberId], references: [memberId], onDelete: Cascade)
  plan     SubscriptionPlan @relation(fields: [planId], references: [planId])
  payments Payment[]

  @@index([memberId])
  @@index([status])
  @@index([endDate])
  @@map("subscriptions")
}

model Attendance {
  attendanceId Int       @id @default(autoincrement()) @map("attendance_id")
  memberId     String    @map("member_id")
  eventType    EventType @map("event_type")
  timestamp    DateTime  @default(now())
  gateId       String?   @map("gate_id") @db.VarChar(10)
  deviceId     String?   @map("device_id") @db.VarChar(20)
  location     String?   @db.VarChar(50)

  // Relations
  member Member @relation(fields: [memberId], references: [memberId], onDelete: Cascade)

  @@index([memberId])
  @@index([timestamp])
  @@index([eventType])
  @@map("attendance")
}

model DoorAccess {
  accessId   Int          @id @default(autoincrement()) @map("access_id")
  memberId   String?      @map("member_id")
  trainerId  String?      @map("trainer_id")
  doorId     String       @map("door_id") @db.VarChar(10)
  accessTime DateTime     @default(now()) @map("access_time")
  accessType AccessType   @map("access_type")
  status     AccessStatus
  reason     String?      @db.VarChar(200)

  // Relations
  member  Member?  @relation(fields: [memberId], references: [memberId], onDelete: SetNull)
  trainer Trainer? @relation(fields: [trainerId], references: [trainerId], onDelete: SetNull)

  @@index([memberId])
  @@index([trainerId])
  @@index([accessTime])
  @@map("door_access")
}

model Appointment {
  appointmentId   String            @id @default(cuid()) @map("appointment_id")
  memberId        String            @map("member_id")
  trainerId       String            @map("trainer_id")
  appointmentDate DateTime          @map("appointment_date") @db.Date
  startTime       DateTime          @map("start_time") @db.Time
  endTime         DateTime          @map("end_time") @db.Time
  status          AppointmentStatus @default(SCHEDULED)
  notes           String?           @db.Text
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")

  // Relations
  member  Member  @relation(fields: [memberId], references: [memberId], onDelete: Cascade)
  trainer Trainer @relation(fields: [trainerId], references: [trainerId])

  @@index([memberId])
  @@index([trainerId])
  @@index([appointmentDate])
  @@index([status])
  @@map("appointments")
}

model WorkoutSchedule {
  scheduleId    String          @id @default(cuid()) @map("schedule_id")
  memberId      String          @map("member_id")
  workoutType   String          @map("workout_type") @db.VarChar(50)
  scheduledDate DateTime        @map("scheduled_date") @db.Date
  scheduledTime DateTime?       @map("scheduled_time") @db.Time
  status        WorkoutStatus   @default(PENDING)
  recurrence    RecurrenceType  @default(NONE)
  notes         String?         @db.Text
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  deletedAt     DateTime?       @map("deleted_at")

  // Relations
  member Member @relation(fields: [memberId], references: [memberId], onDelete: Cascade)

  @@index([memberId])
  @@index([scheduledDate])
  @@index([status])
  @@map("workout_schedules")
}

model WorkoutSession {
  sessionId      String   @id @default(cuid()) @map("session_id")
  memberId       String   @map("member_id")
  workoutType    String   @map("workout_type") @db.VarChar(50)
  startTime      DateTime @map("start_time")
  endTime        DateTime? @map("end_time")
  caloriesBurned Int?     @map("calories_burned")
  notes          String?  @db.Text
  equipmentsUsed Json?    @map("equipments_used") // JSON: [{"equipment": "Bench Press", "duration": 20}]
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  // Relations
  member            Member             @relation(fields: [memberId], references: [memberId], onDelete: Cascade)
  sessionEquipments SessionEquipment[]
  progress          Progress[]

  @@index([memberId])
  @@index([startTime])
  @@map("workout_sessions")
}

model Equipment {
  equipmentId      String           @id @default(cuid()) @map("equipment_id")
  name             String           @db.VarChar(100)
  category         String?          @db.VarChar(50)
  status           EquipmentStatus  @default(ACTIVE)
  location         String?          @db.VarChar(50)
  lastMaintenance  DateTime?        @map("last_maintenance") @db.Date
  nextMaintenance  DateTime?        @map("next_maintenance") @db.Date
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  deletedAt        DateTime?        @map("deleted_at")

  // Relations
  sessionEquipments SessionEquipment[]

  @@index([status])
  @@index([category])
  @@map("equipment")
}

model SessionEquipment {
  sessionId       String @map("session_id")
  equipmentId     String @map("equipment_id")
  durationMinutes Int    @map("duration_minutes")
  notes           String? @db.VarChar(200)

  // Relations
  session   WorkoutSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  equipment Equipment      @relation(fields: [equipmentId], references: [equipmentId])

  @@id([sessionId, equipmentId])
  @@map("session_equipment")
}

model Progress {
  progressId   Int      @id @default(autoincrement()) @map("progress_id")
  memberId     String   @map("member_id")
  sessionId    String?  @map("session_id")
  metricType   String   @map("metric_type") @db.VarChar(50)
  metricValue  Decimal  @map("metric_value") @db.Decimal(10, 2)
  dateRecorded DateTime @map("date_recorded") @db.Date
  notes        String?  @db.Text

  // Relations
  member  Member          @relation(fields: [memberId], references: [memberId], onDelete: Cascade)
  session WorkoutSession? @relation(fields: [sessionId], references: [sessionId], onDelete: SetNull)

  @@index([memberId])
  @@index([dateRecorded])
  @@index([metricType])
  @@map("progress")
}

model Payment {
  paymentId      String        @id @default(cuid()) @map("payment_id")
  memberId       String        @map("member_id")
  subscriptionId String        @map("subscription_id")
  amount         Decimal       @db.Decimal(10, 2)
  paymentDate    DateTime      @default(now()) @map("payment_date")
  paymentMethod  String        @map("payment_method") @db.VarChar(50)
  status         PaymentStatus
  transactionId  String?       @map("transaction_id") @db.VarChar(100)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  // Relations
  member       Member       @relation(fields: [memberId], references: [memberId], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [subscriptionId])

  @@index([memberId])
  @@index([transactionId])
  @@index([paymentDate])
  @@map("payments")
}

model SystemConfig {
  configId     Int       @id @default(autoincrement()) @map("config_id")
  configKey    String    @unique @map("config_key") @db.VarChar(100)
  configValue  String    @map("config_value") @db.Text
  description  String?   @db.VarChar(200)
  lastModified DateTime  @default(now()) @updatedAt @map("last_modified")
  modifiedBy   String?   @map("modified_by")
  createdAt    DateTime  @default(now()) @map("created_at")

  // Relations
  staff Staff? @relation(fields: [modifiedBy], references: [staffId], onDelete: SetNull)

  @@index([configKey])
  @@map("system_config")
}
