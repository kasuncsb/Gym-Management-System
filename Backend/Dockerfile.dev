# ── Dev image (Docker Compose Watch) ──────────────────────────────────────────
# Source is baked in at build time; docker compose watch --sync keeps it updated
# on every save without a container restart or image rebuild.
# Rebuild this image only when package.json changes (watch action: rebuild).
FROM node:22-alpine

# Install redis (needed by entrypoint.sh to start the embedded Redis)
RUN apk add --no-cache redis

WORKDIR /app

# Install ALL deps (including devDependencies — needed for tsx)
COPY package*.json ./
RUN npm ci --ignore-scripts

# Copy source into the image (watch sync will keep it up-to-date at runtime)
COPY . .

RUN chmod +x ./entrypoint.sh

EXPOSE 5000

ENTRYPOINT ["./entrypoint.sh"]
# tsx watch restarts instantly when any .ts file is changed via sync
CMD ["npx", "tsx", "watch", "src/server.ts"]
